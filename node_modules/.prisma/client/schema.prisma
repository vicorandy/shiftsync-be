datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  password         String
  name             String
  role             String // ADMIN, MANAGER, STAFF
  staffProfile     StaffProfile?
  managedLocations Location[]     @relation("LocationManagers")
  notifications    Notification[]
  auditLogs        AuditLog[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Location {
  id        String         @id @default(uuid())
  name      String
  timezone  String
  managers  User[]         @relation("LocationManagers")
  staff     StaffProfile[] @relation("LocationStaff")
  shifts    Shift[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Skill {
  id            String         @id @default(uuid())
  name          String         @unique
  staffProfiles StaffProfile[]
  shifts        Shift[]
}

model StaffProfile {
  id                  String            @id @default(uuid())
  userId              String            @unique
  user                User              @relation(fields: [userId], references: [id])
  skills              Skill[]
  locations           Location[]        @relation("LocationStaff")
  availabilities      Availability[]
  assignments         ShiftAssignment[]
  swapRequests        SwapRequest[]     @relation("Requester")
  swapAcceptances     SwapRequest[]     @relation("Accepter")
  desiredHoursPerWeek Int?
}

model Availability {
  id             String       @id @default(uuid())
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id])
  dayOfWeek      Int? // 0-6 for recurring
  startTime      String // HH:mm
  endTime        String // HH:mm
  startDate      DateTime? // For one-off exceptions
  endDate        DateTime? // For one-off exceptions
  isRecurring    Boolean      @default(true)
}

model Shift {
  id           String            @id @default(uuid())
  locationId   String
  location     Location          @relation(fields: [locationId], references: [id])
  startTime    DateTime
  endTime      DateTime
  skillId      String
  skill        Skill             @relation(fields: [skillId], references: [id])
  headcount    Int               @default(1)
  isPublished  Boolean           @default(false)
  assignments  ShiftAssignment[]
  swapRequests SwapRequest[]
  auditLogs    AuditLog[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model ShiftAssignment {
  id             String       @id @default(uuid())
  shiftId        String
  shift          Shift        @relation(fields: [shiftId], references: [id])
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id])
  assignedAt     DateTime     @default(now())

  @@unique([shiftId, staffProfileId])
}

model SwapRequest {
  id             String        @id @default(uuid())
  shiftId        String
  shift          Shift         @relation(fields: [shiftId], references: [id])
  requesterId    String
  requester      StaffProfile  @relation("Requester", fields: [requesterId], references: [id])
  accepterId     String?
  accepter       StaffProfile? @relation("Accepter", fields: [accepterId], references: [id])
  status         String // PENDING_ACCEPTANCE, PENDING_APPROVAL, APPROVED, REJECTED, CANCELLED
  type           String // SWAP, DROP
  managerComment String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  shiftId   String?
  shift     Shift?   @relation(fields: [shiftId], references: [id])
  action    String
  before    String? // JSON string
  after     String? // JSON string
  timestamp DateTime @default(now())
}
